diff --git a/chrome/browser/extensions/api/echothink_device/echothink_request_proof.cc b/chrome/browser/extensions/api/echothink_device/echothink_request_proof.cc
new file mode 100644
index 0000000..02f290c
--- /dev/null
+++ b/chrome/browser/extensions/api/echothink_device/echothink_request_proof.cc
@@ -0,0 +1,239 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/extensions/api/echothink_device/echothink_request_proof.h"
+
+#include <array>
+#include <string>
+#include <string_view>
+
+#include "base/json/string_escape.h"
+#include "base/strings/string_util.h"
+#include "url/gurl.h"
+
+namespace extensions {
+namespace {
+
+// Server-provided replay nonce upper bound in UTF-8 bytes (T25).
+constexpr size_t kMaxNonceBytes = 256;
+// A base64url SHA-256 digest without padding is always 43 characters.
+constexpr size_t kAccessTokenHashLength = 43;
+
+bool IsAllowedMethod(std::string_view method) {
+  return method == "GET" || method == "POST" || method == "PUT" ||
+         method == "PATCH" || method == "DELETE" || method == "HEAD" ||
+         method == "OPTIONS";
+}
+
+bool IsKnownField(std::string_view key) {
+  return key == "method" || key == "url" || key == "timestamp" ||
+         key == "nonce" || key == "access_token_hash";
+}
+
+// Shape-only RFC3339 UTC validation: YYYY-MM-DDTHH:MM:SS[.fraction]Z. Backend
+// and gateway own accepted clock skew and expiry.
+bool IsCanonicalRfc3339Utc(std::string_view value) {
+  // Minimum length is "2026-05-29T00:00:00Z" == 20 characters.
+  if (value.size() < 20 || value.back() != 'Z') {
+    return false;
+  }
+  auto is_digit = [](char c) { return c >= '0' && c <= '9'; };
+  if (value[4] != '-' || value[7] != '-' || value[10] != 'T' ||
+      value[13] != ':' || value[16] != ':') {
+    return false;
+  }
+  static constexpr std::array<size_t, 14> kDigitPositions = {
+      0, 1, 2, 3, 5, 6, 8, 9, 11, 12, 14, 15, 17, 18};
+  for (size_t pos : kDigitPositions) {
+    if (!is_digit(value[pos])) {
+      return false;
+    }
+  }
+  // Optional fractional seconds occupy positions 19..size()-2, then trailing Z.
+  std::string_view fraction = value.substr(19, value.size() - 20);
+  if (fraction.empty()) {
+    return true;
+  }
+  if (fraction.front() != '.' || fraction.size() < 2) {
+    return false;
+  }
+  for (char c : fraction.substr(1)) {
+    if (!is_digit(c)) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool IsValidNonce(std::string_view nonce) {
+  if (nonce.empty() || nonce.size() > kMaxNonceBytes) {
+    return false;
+  }
+  for (unsigned char c : nonce) {
+    if (c < 0x20 || c == 0x7F) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool IsBase64UrlNoPadding(std::string_view value) {
+  for (char c : value) {
+    const bool ok = (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||
+                    (c >= '0' && c <= '9') || c == '-' || c == '_';
+    if (!ok) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool IsValidAccessTokenHash(std::string_view value) {
+  return value.size() == kAccessTokenHashLength && IsBase64UrlNoPadding(value);
+}
+
+enum class UrlCheck {
+  kOk,
+  // The URL string cannot be parsed as an absolute URL with a host.
+  kInvalid,
+  // The URL parses but is not an allowlisted HTTPS Echothink destination.
+  kDisallowed,
+};
+
+// Validates and canonicalizes the request URL against the exact Echothink
+// signing allowlist. Non-https, userinfo, non-default ports, IP literals,
+// localhost, sibling subdomains, and non-allowlisted path prefixes all resolve
+// to kDisallowed; only an unparseable URL resolves to kInvalid.
+UrlCheck CanonicalizeAllowlistedUrl(const std::string& input,
+                                    std::string* canonical_url) {
+  GURL url(input);
+  if (!url.is_valid() || !url.has_host() || url.host().empty()) {
+    return UrlCheck::kInvalid;
+  }
+  if (!url.SchemeIs("https")) {
+    return UrlCheck::kDisallowed;
+  }
+  if (url.has_username() || url.has_password()) {
+    return UrlCheck::kDisallowed;
+  }
+  if (url.has_port() && url.EffectiveIntPort() != 443) {
+    return UrlCheck::kDisallowed;
+  }
+
+  const std::string host = url.host();
+  const std::string path = url.path();
+  bool allowed = false;
+  if (host == "api.echothink.ai") {
+    allowed = base::StartsWith(path, "/v1/", base::CompareCase::SENSITIVE);
+  } else if (host == "auth.echothink.ai") {
+    allowed =
+        base::StartsWith(path, "/browser/", base::CompareCase::SENSITIVE) ||
+        base::StartsWith(path, "/device/", base::CompareCase::SENSITIVE);
+  } else if (host == "app.echothink.ai") {
+    allowed = base::StartsWith(path, "/api/", base::CompareCase::SENSITIVE);
+  }
+  if (!allowed) {
+    return UrlCheck::kDisallowed;
+  }
+
+  // Strip the fragment because it is never sent to the server. GURL already
+  // lowercases the scheme and host and omits the default :443 port; path and
+  // query semantics are preserved as parsed and query order is not sorted.
+  GURL::Replacements replacements;
+  replacements.ClearRef();
+  *canonical_url = url.ReplaceComponents(replacements).spec();
+  return UrlCheck::kOk;
+}
+
+// Builds the canonical JSON string with string values only, no insignificant
+// whitespace, and the fixed field order. base::Value::Dict cannot be used here
+// because its JSON serialization sorts keys alphabetically.
+std::string BuildCanonicalJson(std::string_view method,
+                               std::string_view url,
+                               std::string_view timestamp,
+                               const std::string* nonce,
+                               const std::string* access_token_hash) {
+  std::string json = "{";
+  json += "\"method\":" + base::GetQuotedJSONString(method);
+  json += ",\"url\":" + base::GetQuotedJSONString(url);
+  json += ",\"timestamp\":" + base::GetQuotedJSONString(timestamp);
+  if (nonce) {
+    json += ",\"nonce\":" + base::GetQuotedJSONString(*nonce);
+  }
+  if (access_token_hash) {
+    json +=
+        ",\"access_token_hash\":" + base::GetQuotedJSONString(*access_token_hash);
+  }
+  json += "}";
+  return json;
+}
+
+}  // namespace
+
+RequestProofResult BuildCanonicalRequestProof(
+    const base::Value::Dict& options) {
+  RequestProofResult result;
+
+  // Reject unknown fields up front (defense in depth over the IDL binding).
+  for (const auto entry : options) {
+    if (!IsKnownField(entry.first)) {
+      return result;  // kInvalidPayload
+    }
+  }
+
+  const std::string* method = options.FindString("method");
+  const std::string* url = options.FindString("url");
+  const std::string* timestamp = options.FindString("timestamp");
+  if (!method || !url || !timestamp) {
+    return result;  // kInvalidPayload
+  }
+  if (!IsAllowedMethod(*method) || !IsCanonicalRfc3339Utc(*timestamp)) {
+    return result;  // kInvalidPayload
+  }
+
+  // Optional nonce. Present-but-wrong-type or out-of-bounds is rejected.
+  std::string nonce;
+  const std::string* nonce_ptr = nullptr;
+  if (const base::Value* nonce_value = options.Find("nonce");
+      nonce_value && !nonce_value->is_none()) {
+    if (!nonce_value->is_string() || !IsValidNonce(nonce_value->GetString())) {
+      return result;  // kInvalidPayload
+    }
+    nonce = nonce_value->GetString();
+    nonce_ptr = &nonce;
+  }
+
+  // Optional access token hash. The helper accepts only the hash, never a raw
+  // token.
+  std::string token_hash;
+  const std::string* token_hash_ptr = nullptr;
+  if (const base::Value* token_hash_value = options.Find("access_token_hash");
+      token_hash_value && !token_hash_value->is_none()) {
+    if (!token_hash_value->is_string() ||
+        !IsValidAccessTokenHash(token_hash_value->GetString())) {
+      return result;  // kInvalidPayload
+    }
+    token_hash = token_hash_value->GetString();
+    token_hash_ptr = &token_hash;
+  }
+
+  std::string canonical_url;
+  switch (CanonicalizeAllowlistedUrl(*url, &canonical_url)) {
+    case UrlCheck::kInvalid:
+      return result;  // kInvalidPayload
+    case UrlCheck::kDisallowed:
+      result.status = RequestProofStatus::kDisallowedDestination;
+      return result;
+    case UrlCheck::kOk:
+      break;
+  }
+
+  result.canonical_json = BuildCanonicalJson(*method, canonical_url, *timestamp,
+                                             nonce_ptr, token_hash_ptr);
+  result.timestamp = *timestamp;
+  result.status = RequestProofStatus::kOk;
+  return result;
+}
+
+}  // namespace extensions
