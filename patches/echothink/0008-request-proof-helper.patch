@@ -0,0 +1,46 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_EXTENSIONS_API_ECHOTHINK_DEVICE_ECHOTHINK_REQUEST_PROOF_H_
+#define CHROME_BROWSER_EXTENSIONS_API_ECHOTHINK_DEVICE_ECHOTHINK_REQUEST_PROOF_H_
+
+#include <string>
+
+#include "base/values.h"
+
+namespace extensions {
+
+// Outcome of validating and canonicalizing a request-proof options dictionary
+// supplied by the bundled Echothink workspace extension. See
+// docs/echothink-browser-alpha/t25-define-request-proof-payload-and-allowlist.md.
+enum class RequestProofStatus {
+  kOk,
+  // The payload is missing required fields, has the wrong type, contains
+  // unknown fields, or otherwise fails the canonical request-proof shape.
+  kInvalidPayload,
+  // The payload is well-formed but the request URL is not an allowlisted
+  // Echothink signing destination.
+  kDisallowedDestination,
+};
+
+struct RequestProofResult {
+  RequestProofStatus status = RequestProofStatus::kInvalidPayload;
+  // Canonical UTF-8 JSON bytes to be signed. Populated only when status is
+  // kOk. The field order is method, url, timestamp, nonce, access_token_hash,
+  // with optional fields omitted entirely when absent.
+  std::string canonical_json;
+  // Canonical request timestamp echoed back to the caller. Populated only when
+  // status is kOk.
+  std::string timestamp;
+};
+
+// Validates the structured request-proof options, enforces the exact Echothink
+// HTTPS signing allowlist, and builds the canonical JSON payload to be signed.
+// On failure it never returns the rejected URL, query string, nonce, or token;
+// callers map the status to a coarse error code only.
+RequestProofResult BuildCanonicalRequestProof(const base::Value::Dict& options);
+
+}  // namespace extensions
+
+#endif  // CHROME_BROWSER_EXTENSIONS_API_ECHOTHINK_DEVICE_ECHOTHINK_REQUEST_PROOF_H_
