+constexpr char kEchothinkAuthSessionReadyPref[] =
+    "echothink.auth.session_ready";
+constexpr char kEchothinkDeviceEnrolledPref[] = "echothink.device.enrolled";
+constexpr char kEchothinkDeviceVerifiedPref[] = "echothink.device.verified";
+constexpr char kEchothinkSetupCompletePref[] = "echothink.setup.complete";
+constexpr char kEchothinkFirstRunURL[] = "chrome://echothink-first-run";
+
+PrefService* GetEchothinkLoginGatePrefs(Profile* profile) {
+  if (!profile) {
+    return nullptr;
+  }
+  return profile->GetOriginalProfile()->GetPrefs();
+}
+
+bool IsEchothinkSetupComplete(Profile* profile) {
+  PrefService* prefs = GetEchothinkLoginGatePrefs(profile);
+  if (!prefs) {
+    return false;
+  }
+
+  const bool ready =
+      prefs->GetBoolean(kEchothinkAuthSessionReadyPref) &&
+      prefs->GetBoolean(kEchothinkDeviceEnrolledPref) &&
+      prefs->GetBoolean(kEchothinkDeviceVerifiedPref);
+  if (prefs->GetBoolean(kEchothinkSetupCompletePref) != ready) {
+    prefs->SetBoolean(kEchothinkSetupCompletePref, ready);
+  }
+  return ready;
+}
+
+bool IsEchothinkAllowedChromeURL(const GURL& url) {
+  if (!url.SchemeIs(content::kChromeUIScheme)) {
+    return false;
+  }
+
+  const std::string host = url.host();
+  if (host == "echothink-first-run" || host == "echothink-diagnostics" ||
+      host == chrome::kChromeUIVersionHost || host == "policy" ||
+      host == "extensions") {
+    return true;
+  }
+
+  return host == "settings" && url.path_piece() == "/help";
+}
+
+bool IsEchothinkAllowedHTTPSURL(const GURL& url) {
+  if (!url.SchemeIs(url::kHttpsScheme)) {
+    return false;
+  }
+
+  const std::string host = url.host();
+  const std::string path = url.path();
+
+  if (host == "updates.echothink.ai") {
+    return true;
+  }
+  if (host == "auth.echothink.ai") {
+    return path == "/login" || path == "/browser/callback" ||
+           path == "/device/enroll" || path == "/device/complete";
+  }
+  if (host == "app.echothink.ai") {
+    return path == "/browser-required" || path == "/support" ||
+           path == "/download-browser";
+  }
+  return false;
+}
+
+bool IsEchothinkAllowedPreSetupURL(const GURL& url) {
+  return IsEchothinkAllowedChromeURL(url) || IsEchothinkAllowedHTTPSURL(url);
+}
+
+void ApplyEchothinkLoginGate(NavigateParams* params) {
+  if (!params || !params->initiating_profile) {
+    return;
+  }
+
+  if (IsEchothinkSetupComplete(params->initiating_profile) ||
+      IsEchothinkAllowedPreSetupURL(params->url)) {
+    return;
+  }
+
+  // Echothink Browser login gate (T21): before setup completes, replace
+  // browser-level top-frame navigation to arbitrary destinations with the
+  // local setup/recovery shell. Do not carry the blocked URL, query, fragment,
+  // or referrer into the local page.
+  params->url = GURL(kEchothinkFirstRunURL);
+  params->referrer = content::Referrer();
+}
