+constexpr char kEchothinkAuthSessionReadyPref[] =
+    "echothink.auth.session_ready";
+constexpr char kEchothinkDeviceEnrolledPref[] = "echothink.device.enrolled";
+constexpr char kEchothinkDeviceVerifiedPref[] = "echothink.device.verified";
+constexpr char kEchothinkSetupCompletePref[] = "echothink.setup.complete";
+constexpr char kEchothinkSetupCompletedAtPref[] =
+    "echothink.setup.completed_at";
+constexpr char kEchothinkLastBlockedAtPref[] =
+    "echothink.setup.last_blocked_at";
+constexpr char kEchothinkLastBlockedSchemePref[] =
+    "echothink.setup.last_blocked_scheme";
+constexpr char kEchothinkFirstRunURL[] = "chrome://echothink-first-run";
+
+PrefService* GetEchothinkLoginGatePrefs(Profile* profile) {
+  if (!profile) {
+    return nullptr;
+  }
+  return profile->GetOriginalProfile()->GetPrefs();
+}
+
+bool IsEchothinkSetupComplete(Profile* profile) {
+  PrefService* prefs = GetEchothinkLoginGatePrefs(profile);
+  if (!prefs) {
+    return false;
+  }
+
+  const bool ready =
+      prefs->GetBoolean(kEchothinkAuthSessionReadyPref) &&
+      prefs->GetBoolean(kEchothinkDeviceEnrolledPref) &&
+      prefs->GetBoolean(kEchothinkDeviceVerifiedPref);
+  if (prefs->GetBoolean(kEchothinkSetupCompletePref) != ready) {
+    prefs->SetBoolean(kEchothinkSetupCompletePref, ready);
+  }
+  return ready;
+}
