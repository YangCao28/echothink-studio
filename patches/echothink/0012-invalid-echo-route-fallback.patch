+// Echothink Browser: local invalid echo:// route fallback page.
+//
+// This page is intentionally generic. It never displays the original echo://
+// route because unsupported routes may include protected resource identifiers
+// or other opaque payloads. Known routes are handled by the echo resolver in
+// browser_navigator.cc; this page is only for the safe failure path.
+class EchothinkInvalidEchoDataSource : public content::URLDataSource {
+ public:
+  EchothinkInvalidEchoDataSource() {}
+  EchothinkInvalidEchoDataSource(const EchothinkInvalidEchoDataSource&) =
+      delete;
+  EchothinkInvalidEchoDataSource& operator=(
+      const EchothinkInvalidEchoDataSource&) = delete;
+
+  std::string GetSource() { return "echothink-invalid-echo"; }
+  std::string GetMimeType(const GURL& url) { return "text/html"; }
+
+  void StartDataRequest(const GURL& url,
+                        const content::WebContents::Getter& wc_getter,
+                        GotDataCallback callback) {
+    std::string source = R"(
+<!doctype html>
+<title>Unsupported Echothink Link</title>
+<meta charset="utf-8">
+<meta name="color-scheme" content="light dark">
+<style>
+ @import url(chrome://resources/css/text_defaults_md.css);
+ html{color:#202124; background:#f5f6f7; line-height:1.4}
+ body{margin:0}
+ a{color:#1967d2; text-decoration:none}
+ a:hover{text-decoration:underline}
+ main{max-width:42em; margin:5em auto; padding:0 1.5em}
+ section{background:white; border-radius:.75em; padding:2em 2.25em; margin-bottom:1.5em;
+         box-shadow:0 .063em .125em 0 #c4c5c6, 0 .125em .375em .125em #e2e3e3}
+ h1{font-size:1.5em; margin:0 0 .25em}
+ h2{font-size:1.05em; margin:0 0 .75em}
+ p{margin:.5em 0; color:#3c4043}
+ ul{list-style:none; padding:0; margin:.5em 0}
+ li{padding:.4em 0; border-top:.063em solid #f0f0f0}
+ li:first-child{border-top:none}
+ .desc{color:#5f6368; font-size:.9em}
+ footer{text-align:center; color:#5f6368; font-size:.85em; margin-top:2em}
+ @media(prefers-color-scheme:dark){
+  html{color:#e8eaed; background:#202124}
+  a{color:#8ab4f8}
+  section{background:#292a2d; box-shadow:0 .063em .125em 0 #161719, 0 .125em .375em .125em #1b1c1f}
+  p{color:#bdc1c6}
+  li{border-top:.063em solid #3f4042}
+  .desc{color:#9aa0a6}
+ }
+</style>
+<main>
+ <section>
+  <h1>Unsupported Echothink link</h1>
+  <p>The link in this tab uses an invalid or unsupported Echothink route. The
+   route was not loaded, forwarded, or displayed.</p>
+  <p>This local browser page does not contain workspace data, project details,
+   artifact identifiers, approval details, or the original link.</p>
+ </section>
+ <section>
+  <h2>Continue safely</h2>
+  <ul>
+   <li><a href="https://app.echothink.ai/dashboard">Open workspace</a>
+    <div class="desc">Go to your Echothink dashboard.</div></li>
+   <li><a href="chrome://echothink-first-run">Browser setup</a>
+    <div class="desc">Return to the local sign-in and device setup page.</div></li>
+   <li><a href="https://app.echothink.ai/support">Contact support</a>
+    <div class="desc">Get help with an Echothink Browser link.</div></li>
+  </ul>
+ </section>
+ <footer>
+  This page can always be reached at chrome://echothink-invalid-echo
+ </footer>
+</main>
+)";
+    std::move(callback).Run(
+        base::MakeRefCounted<base::RefCountedString>(std::move(source)));
+  }
+};
+
+class EchothinkInvalidEcho;
+class EchothinkInvalidEchoUIConfig
+    : public content::DefaultWebUIConfig<EchothinkInvalidEcho> {
+ public:
+  EchothinkInvalidEchoUIConfig()
+      : DefaultWebUIConfig("chrome", "echothink-invalid-echo") {}
+};
+
+class EchothinkInvalidEcho : public content::WebUIController {
+ public:
+  EchothinkInvalidEcho(content::WebUI* web_ui)
+      : content::WebUIController(web_ui) {
+    content::URLDataSource::Add(
+        Profile::FromWebUI(web_ui),
+        std::make_unique<EchothinkInvalidEchoDataSource>());
+  }
+  EchothinkInvalidEcho(const EchothinkInvalidEcho&) = delete;
+  EchothinkInvalidEcho& operator=(const EchothinkInvalidEcho&) = delete;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_ECHOTHINK_INVALID_ECHO_H_
