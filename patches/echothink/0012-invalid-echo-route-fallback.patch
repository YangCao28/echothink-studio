# Echothink-Patch: 0012-invalid-echo-route-fallback
# Title: Add local invalid echo route fallback page
# Area: echo-router
# Depends-On: echothink/0009-echo-protocol-router.patch
# Inherited-Depends-On: extra/ungoogled-chromium/first-run-page.patch (reuses the local WebUI URLDataSource pattern already used by the Echothink first-run page)
# Browser-Layer-Reason: echo:// links are browser-shell navigation shortcuts. Invalid shortcut failures must be handled before Chromium treats the custom scheme as an external protocol, and a backend page cannot safely render the failure because the unsupported route may contain protected resource identifiers. The browser can show a generic local error without forwarding or displaying the original route.
# Preferred-Surface-Checked: existing-hook, native-required (builds on the T28 NavigateParams echo resolver hook and the existing local WebUI pattern; policy/preference/extension surfaces cannot reliably catch every typed or clicked custom-scheme navigation before external protocol handling)
# Security-Critical-Areas: none
# Native-Files-Touched: chrome/browser/ui/browser_navigator.cc, chrome/browser/ui/webui/echothink_invalid_echo.h (new), chrome/browser/ui/webui/chrome_web_ui_configs.cc, chrome/common/webui_url_constants.cc
# Rebase-Risk: medium (depends on the T28 browser_navigator.cc resolver block and the local WebUI registration locations used by T10)
# Validation: Apply inherited patches and active Echothink predecessors through 0009, then this patch with `patch -p1` against pinned Chromium 148.0.7778.178; launch and verify echo://dashboard still resolves to https://app.echothink.ai/dashboard while echo://unknown, echo://project, echo://project/secret?token=1, and echo://artifact/private#frag show chrome://echothink-invalid-echo. Confirm the page never displays the original echo:// route, route segments, query, fragment, or workspace data.
#
# Notes:
# - Known routes still resolve to HTTPS app URLs through 0009. This patch only
#   changes the failure path for echo:// URLs that 0009 refuses to resolve.
# - Invalid routes are rewritten to a static local chrome:// page with no query
#   parameters and no fragment, so the original route is not exposed in the
#   visible fallback URL or page content.
# - The fallback page contains no JavaScript, performs no network request by
#   itself, and embeds no workspace, project, task-wave, artifact, approval, or
#   app-domain data. Its links are limited to workspace dashboard, setup, and
#   support destinations.
# - Backend services remain responsible for authorization and device proof for
#   any HTTPS workspace destination opened from the page.

--- a/chrome/browser/ui/browser_navigator.cc
+++ b/chrome/browser/ui/browser_navigator.cc
@@ -146,6 +146,8 @@ bool IncognitoModeForced(const Profile*
 
 constexpr std::string_view kEchoURLPrefix = "echo://";
 constexpr std::string_view kEchothinkAppOrigin = "https://app.echothink.ai";
+constexpr char kEchothinkInvalidEchoURL[] =
+    "chrome://echothink-invalid-echo";
 
 bool IsSafeEchoRouteSegment(std::string_view segment) {
   if (segment.empty()) {
@@ -233,6 +235,23 @@ std::optional<GURL> ResolveEchoURL(const
   return std::nullopt;
 }
 
+void RewriteEchoURLOrFallback(NavigateParams* params) {
+  if (!params->url.SchemeIs("echo")) {
+    return;
+  }
+
+  if (std::optional<GURL> echo_url = ResolveEchoURL(params->url)) {
+    params->url = *echo_url;
+  } else {
+    // Never carry the invalid route, route segments, query, or fragment into
+    // the local fallback URL.
+    params->url = GURL(kEchothinkInvalidEchoURL);
+  }
+
+  // Do not leak the source of an echo:// shortcut as an HTTPS or chrome:// referrer.
+  params->referrer = content::Referrer();
+}
+
 // Change some of the navigation parameters based on the particular URL.
 // Returns true on success. Otherwise, if changing params leads the browser
 // into an erroneous state, returns false.
@@ -663,12 +681,7 @@ base::WeakPtr<content::NavigationHandle>
     }
   }
 
-  if (std::optional<GURL> echo_url = ResolveEchoURL(params->url)) {
-    params->url = *echo_url;
-    // Do not leak the source of an echo:// shortcut as an HTTPS referrer.
-    params->referrer = content::Referrer();
-  }
-
+  RewriteEchoURLOrFallback(params);
   // Open System Apps in their standalone window if necessary.
