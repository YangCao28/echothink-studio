# Echothink-Patch: 0018-side-panel-local-states
# Title: Add resilient local states to the Echothink Side Panel
# Area: extension
# Depends-On: echothink/0004-bundled-workspace-extension.patch, echothink/0014-side-panel-container.patch, echothink/0015-side-panel-mode-selector.patch, echothink/0017-workspace-context-shell.patch, echothink/0016-chat-panel-shell.patch
# Browser-Layer-Reason: The bundled Side Panel must explain local setup and service failure states before or while Echothink services are unavailable. Keeping this in the MV3 extension gives the browser shell safe recovery UI without adding backend logic or native Chromium UI rewrites.
# Preferred-Surface-Checked: extension (local sidepanel.html/sidepanel.css/sidepanel.js UI plus a narrow first-party content-bridge state message)
# Security-Critical-Areas: none
# Native-Files-Touched: chrome/browser/resources/echothink_workspace/content_bridge.js, chrome/browser/resources/echothink_workspace/sidepanel.html, chrome/browser/resources/echothink_workspace/sidepanel.css, chrome/browser/resources/echothink_workspace/sidepanel.js
# Rebase-Risk: low (updates only bundled extension resource files added by echothink/0004)
# Validation: Apply inherited patches, then active Echothink predecessors through echothink/0016 and this patch with `patch -p1` against pinned Chromium 148.0.7778.178; launch a fresh profile, open the Side Panel, and verify signed_out, no_device_identity, unauthorized_scope, offline, and remote_service_error states show recovery actions while signed-out/device/unauthorized states hide Chat and Workspace Context protected content.
#
# Notes:
# - Local state values are stored under `echothink.sidePanel.localState` and can
#   be updated by the trusted extension or by first-party app/auth pages through
#   the existing content bridge using `side_panel_state` messages.
# - Protected Side Panel content is hidden and reset for signed-out,
#   no-device-identity, and unauthorized-scope states.
# - No extension permissions, host permissions, native messaging, backend
#   business logic, token/private-key handling, network stack, TLS, sandbox,
#   renderer, downloads, history, bookmarks, password manager, cookies, or
#   DevTools behavior is changed.

--- a/chrome/browser/resources/echothink_workspace/content_bridge.js
+++ b/chrome/browser/resources/echothink_workspace/content_bridge.js
@@ -1,5 +1,6 @@
 const BRIDGE_CHANNEL = "echothink.workspace.bridge";
 const BRIDGE_VERSION = "0.1.0";
+const SIDE_PANEL_LOCAL_STATE_UPDATE_TYPE = "echothink.sidePanel.localState.update";
 const ALLOWED_PAGE_ORIGINS = new Set([
   "https://app.echothink.ai",
   "https://auth.echothink.ai",
@@ -14,22 +15,42 @@ function isBridgeRequest(value) {
   );
 }
 
+function isLocalStateUpdate(value) {
+  return (
+    value &&
+    typeof value === "object" &&
+    value.channel === BRIDGE_CHANNEL &&
+    value.type === "side_panel_state" &&
+    value.payload
+  );
+}
+
 window.addEventListener("message", (event) => {
-  if (
-    event.source !== window ||
-    !ALLOWED_PAGE_ORIGINS.has(event.origin) ||
-    !isBridgeRequest(event.data)
-  ) {
+  if (event.source !== window || !ALLOWED_PAGE_ORIGINS.has(event.origin)) {
     return;
   }
 
-  window.postMessage(
-    {
-      channel: BRIDGE_CHANNEL,
-      type: "ready",
-      version: BRIDGE_VERSION,
-      capabilities: [],
-    },
-    event.origin,
-  );
+  if (isBridgeRequest(event.data)) {
+    window.postMessage(
+      {
+        channel: BRIDGE_CHANNEL,
+        type: "ready",
+        version: BRIDGE_VERSION,
+        capabilities: ["side_panel_state"],
+      },
+      event.origin,
+    );
+    return;
+  }
+
+  if (isLocalStateUpdate(event.data)) {
+    chrome.runtime
+      ?.sendMessage?.({
+        type: SIDE_PANEL_LOCAL_STATE_UPDATE_TYPE,
+        payload: event.data.payload,
+      })
+      ?.catch((error) => {
+        console.warn("Unable to forward side panel state", error);
+      });
+  }
 });
