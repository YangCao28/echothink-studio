+EnsureDeviceIdentityResult EnsureDeviceIdentity(
+    PrefService* local_state,
+    const base::FilePath& user_data_dir) {
+#if !BUILDFLAG(IS_WIN)
+  return EnsureDeviceIdentityResult::kUnsupportedPlatform;
+#else
+  if (!local_state || user_data_dir.empty()) {
+    return EnsureDeviceIdentityResult::kStorageError;
+  }
+
+  EnsureInstallationId(local_state);
+  const base::FilePath key_path =
+      GetProtectedKeyFilePathForUserDataDir(user_data_dir);
+  if (base::PathExists(key_path)) {
+    std::optional<crypto::keypair::PrivateKey> private_key =
+        ReadProtectedKeyEnvelope(key_path);
+    if (!private_key) {
+      return EnsureDeviceIdentityResult::kInvalidProtectedKey;
+    }
+    std::optional<PublicKeyMetadata> metadata =
+        BuildPublicKeyMetadata(*private_key);
+    if (!metadata) {
+      return EnsureDeviceIdentityResult::kInvalidProtectedKey;
+    }
+
+    std::string key_created_at =
+        local_state->GetString(kDeviceKeyCreatedAtPref);
+    if (key_created_at.empty()) {
+      key_created_at = NowAsIso8601Utc();
+    }
+    StoreKeyMetadata(local_state, std::move(*metadata), key_created_at);
+    return EnsureDeviceIdentityResult::kReady;
+  }
+
+  crypto::keypair::PrivateKey private_key =
+      crypto::keypair::PrivateKey::GenerateEcP256();
+  std::optional<PublicKeyMetadata> metadata =
+      BuildPublicKeyMetadata(private_key);
+  if (!metadata) {
+    return EnsureDeviceIdentityResult::kStorageError;
+  }
+
+  const std::vector<uint8_t> private_key_info =
+      private_key.ToPrivateKeyInfo();
+  if (!WriteProtectedKeyEnvelope(key_path, metadata->key_id,
+                                 private_key_info)) {
+    return EnsureDeviceIdentityResult::kStorageError;
+  }
+
+  StoreKeyMetadata(local_state, std::move(*metadata), NowAsIso8601Utc());
+  return EnsureDeviceIdentityResult::kGenerated;
+#endif
+}
