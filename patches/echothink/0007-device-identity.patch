+constexpr int kProtectedKeySchemaVersion = 1;
+constexpr char kIdentityDirectoryName[] = "Echothink Device Identity";
+constexpr char kProtectedKeyFileName[] = "device_key.dpapi";
+constexpr char kEnvelopeSchemaVersion[] = "schema_version";
+constexpr char kEnvelopeStorage[] = "storage";
+constexpr char kEnvelopeKeyAlgorithm[] = "key_algorithm";
+constexpr char kEnvelopeKeyId[] = "key_id";
+constexpr char kEnvelopeProtectedPayload[] = "protected_payload";
+constexpr char kEnrollmentStatusNone[] = "none";
+constexpr char kJwkThumbprintPrefix[] = "jkt:";
+
+// X.509 SubjectPublicKeyInfo prefix for an uncompressed P-256 public key.
+constexpr std::array<uint8_t, 27> kP256SpkiPrefix = {
+    0x30, 0x59, 0x30, 0x13, 0x06, 0x07, 0x2a, 0x86, 0x48,
+    0xce, 0x3d, 0x02, 0x01, 0x06, 0x08, 0x2a, 0x86, 0x48,
+    0xce, 0x3d, 0x03, 0x01, 0x07, 0x03, 0x42, 0x00, 0x04};
+
+struct PublicKeyMetadata {
+  base::Value::Dict public_jwk;
+  std::string key_id;
+};
+
+std::string_view BytesAsStringView(const uint8_t* data, size_t size) {
+  if (size == 0) {
+    return std::string_view();
+  }
+  return std::string_view(reinterpret_cast<const char*>(data), size);
+}
+
+std::string BytesToBase64(const std::vector<uint8_t>& bytes) {
+  return base::Base64Encode(BytesAsStringView(bytes.data(), bytes.size()));
+}
+
+std::string BytesToBase64Url(std::string_view bytes) {
+  std::string encoded;
+  base::Base64UrlEncode(bytes, base::Base64UrlEncodePolicy::OMIT_PADDING,
+                        &encoded);
+  return encoded;
+}
+
+std::string NowAsIso8601Utc() {
+  base::Time::Exploded exploded;
+  base::Time::Now().UTCExplode(&exploded);
+  return base::StringPrintf("%04d-%02d-%02dT%02d:%02d:%02d.%03dZ",
+                            exploded.year, exploded.month,
+                            exploded.day_of_month, exploded.hour,
+                            exploded.minute, exploded.second,
+                            exploded.millisecond);
+}
+
+std::string NewInstallationId() {
+  return base::Uuid::GenerateRandomV4().AsLowercaseString();
+}
+
+std::string CurrentBrowserChannel() {
+  std::string channel(version_info::GetChannelString(chrome::GetChannel()));
+  if (channel.empty() || channel == "unknown") {
+    return "dev";
+  }
+  return channel;
+}
