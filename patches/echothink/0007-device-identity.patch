+bool HasProtectedDeviceKey(PrefService* local_state,
+                           const base::FilePath& user_data_dir) {
+  return local_state && !user_data_dir.empty() &&
+         base::PathExists(GetProtectedKeyFilePathForUserDataDir(user_data_dir));
+}
+
+bool ResetLocalEnrollmentState(PrefService* local_state,
+                               PrefService* profile_prefs,
+                               const base::FilePath& user_data_dir) {
+  if (!local_state || user_data_dir.empty()) {
+    return false;
+  }
+
+  const base::FilePath key_path =
+      GetProtectedKeyFilePathForUserDataDir(user_data_dir);
+  if (base::PathExists(key_path) && !base::DeleteFile(key_path)) {
+    return false;
+  }
+
+  ClearLocalKeyMetadata(local_state);
+  local_state->SetString(kDeviceInstallationIdPref, NewInstallationId());
+  RefreshBrowserMetadata(local_state);
+  ClearProfileEnrollmentPrefs(profile_prefs);
+  return true;
+}
+
+base::FilePath GetDeviceIdentityDirectoryForUserDataDir(
+    const base::FilePath& user_data_dir) {
+  return user_data_dir.AppendASCII(kIdentityDirectoryName);
+}
+
+base::FilePath GetProtectedKeyFilePathForUserDataDir(
+    const base::FilePath& user_data_dir) {
+  return GetDeviceIdentityDirectoryForUserDataDir(user_data_dir)
+      .AppendASCII(kProtectedKeyFileName);
+}
