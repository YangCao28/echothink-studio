+std::optional<PublicKeyMetadata> BuildPublicKeyMetadata(
+    const crypto::keypair::PrivateKey& private_key) {
+  std::vector<uint8_t> spki = private_key.ToSubjectPublicKeyInfo();
+  constexpr size_t kCoordinateLength = 32;
+  constexpr size_t kExpectedLength =
+      kP256SpkiPrefix.size() + (2 * kCoordinateLength);
+  if (spki.size() != kExpectedLength ||
+      !std::equal(kP256SpkiPrefix.begin(), kP256SpkiPrefix.end(),
+                  spki.begin())) {
+    return std::nullopt;
+  }
+
+  const uint8_t* coordinates = spki.data() + kP256SpkiPrefix.size();
+  const std::string x = BytesToBase64Url(
+      BytesAsStringView(coordinates, kCoordinateLength));
+  const std::string y = BytesToBase64Url(
+      BytesAsStringView(coordinates + kCoordinateLength, kCoordinateLength));
+
+  const std::string thumbprint_json = base::StringPrintf(
+      "{\"crv\":\"P-256\",\"kty\":\"EC\",\"x\":\"%s\",\"y\":\"%s\"}",
+      x.c_str(), y.c_str());
+  const std::string thumbprint =
+      BytesToBase64Url(crypto::SHA256HashString(thumbprint_json));
+
+  PublicKeyMetadata metadata;
+  metadata.public_jwk.Set("kty", "EC");
+  metadata.public_jwk.Set("crv", "P-256");
+  metadata.public_jwk.Set("x", x);
+  metadata.public_jwk.Set("y", y);
+  metadata.public_jwk.Set("alg", kDeviceKeyAlgorithm);
+  metadata.key_id = std::string(kJwkThumbprintPrefix) + thumbprint;
+  return metadata;
+}
+
+bool ProtectPrivateKey(const std::vector<uint8_t>& private_key_info,
+                       std::vector<uint8_t>* protected_payload) {
+#if BUILDFLAG(IS_WIN)
+  DATA_BLOB input;
+  input.pbData = const_cast<BYTE*>(
+      reinterpret_cast<const BYTE*>(private_key_info.data()));
+  input.cbData = base::checked_cast<DWORD>(private_key_info.size());
+
+  DATA_BLOB output;
+  BOOL result = CryptProtectData(&input, L"Echothink Device Identity", nullptr,
+                                 nullptr, nullptr, CRYPTPROTECT_UI_FORBIDDEN,
+                                 &output);
+  if (!result) {
+    return false;
+  }
+
+  protected_payload->assign(output.pbData, output.pbData + output.cbData);
+  LocalFree(output.pbData);
+  return true;
+#else
+  return false;
+#endif
+}
+
+bool UnprotectPrivateKey(const std::vector<uint8_t>& protected_payload,
+                         std::vector<uint8_t>* private_key_info) {
+#if BUILDFLAG(IS_WIN)
+  DATA_BLOB input;
+  input.pbData =
+      const_cast<BYTE*>(reinterpret_cast<const BYTE*>(protected_payload.data()));
+  input.cbData = base::checked_cast<DWORD>(protected_payload.size());
+
+  DATA_BLOB output;
+  BOOL result =
+      CryptUnprotectData(&input, nullptr, nullptr, nullptr, nullptr,
+                         CRYPTPROTECT_UI_FORBIDDEN, &output);
+  if (!result) {
+    return false;
+  }
+
+  private_key_info->assign(output.pbData, output.pbData + output.cbData);
+  LocalFree(output.pbData);
+  return true;
+#else
+  return false;
+#endif
+}
+
+bool WriteProtectedKeyEnvelope(const base::FilePath& key_path,
+                               const std::string& key_id,
+                               const std::vector<uint8_t>& private_key_info) {
+  std::vector<uint8_t> protected_payload;
+  if (!ProtectPrivateKey(private_key_info, &protected_payload)) {
+    return false;
+  }
+
+  base::Value::Dict envelope;
+  envelope.Set(kEnvelopeSchemaVersion, kProtectedKeySchemaVersion);
+  envelope.Set(kEnvelopeStorage, kDeviceKeyStorage);
+  envelope.Set(kEnvelopeKeyAlgorithm, kDeviceKeyAlgorithm);
+  envelope.Set(kEnvelopeKeyId, key_id);
+  envelope.Set(kEnvelopeProtectedPayload, BytesToBase64(protected_payload));
+
+  std::string json;
+  if (!base::JSONWriter::Write(envelope, &json) ||
+      !base::CreateDirectory(key_path.DirName())) {
+    return false;
+  }
+  return base::WriteFile(key_path, json);
+}
+
+std::optional<crypto::keypair::PrivateKey> ReadProtectedKeyEnvelope(
+    const base::FilePath& key_path) {
+  std::string json;
+  if (!base::ReadFileToString(key_path, &json)) {
+    return std::nullopt;
+  }
+
+  std::optional<base::Value::Dict> envelope = base::JSONReader::ReadDict(json);
+  if (!envelope) {
+    return std::nullopt;
+  }
+
+  std::optional<int> schema_version =
+      envelope->FindInt(kEnvelopeSchemaVersion);
+  const std::string* storage = envelope->FindString(kEnvelopeStorage);
+  const std::string* key_algorithm =
+      envelope->FindString(kEnvelopeKeyAlgorithm);
+  const std::string* protected_payload_base64 =
+      envelope->FindString(kEnvelopeProtectedPayload);
+  if (!schema_version || *schema_version != kProtectedKeySchemaVersion ||
+      !storage || *storage != kDeviceKeyStorage || !key_algorithm ||
+      *key_algorithm != kDeviceKeyAlgorithm || !protected_payload_base64) {
+    return std::nullopt;
+  }
+
+  std::optional<std::vector<uint8_t>> protected_payload =
+      base::Base64Decode(*protected_payload_base64);
+  if (!protected_payload) {
+    return std::nullopt;
+  }
+
+  std::vector<uint8_t> private_key_info;
+  if (!UnprotectPrivateKey(*protected_payload, &private_key_info)) {
+    return std::nullopt;
+  }
+
+  std::optional<crypto::keypair::PrivateKey> private_key =
+      crypto::keypair::PrivateKey::FromPrivateKeyInfo(private_key_info);
+  if (!private_key || !private_key->IsEc()) {
+    return std::nullopt;
+  }
+  return private_key;
+}
