+
+// Bundled Echothink Workspace extension bridge for local device identity.
+// This API is allowlisted to the bundled component extension ID only. It never
+// exposes private key bytes, DPAPI blobs, access tokens, or raw key handles.
+namespace echothinkDevice {
+  dictionary SignProofPayloadOptions {
+    // Canonical payload bytes represented as a UTF-8 string. T25/T26 define
+    // the protected request-proof canonicalization and domain allowlist before
+    // this result is attached to service API requests.
+    DOMString payload;
+  };
+
+  callback BridgeResultCallback = void(object result);
+
+  interface Functions {
+    // Returns non-secret local device metadata and enrollment readiness state.
+    // Error result codes include missing_device, locked_key,
+    // unsupported_platform, and reset.
+    static void getDeviceStatus(BridgeResultCallback callback);
+
+    // Returns public-key registration material and non-secret browser metadata
+    // for enrollment. This does not call backend services.
+    static void requestEnrollmentChallenge(BridgeResultCallback callback);
+
+    // Signs a proof payload with the browser-owned device key and returns only
+    // the signature result. Private key material remains native-only.
+    static void signProofPayload(
+        SignProofPayloadOptions options,
+        BridgeResultCallback callback);
+
+    // Explicitly clears local enrollment state and removes the protected local
+    // key so the next enrollment starts from a new identity.
+    static void clearEnrollment(BridgeResultCallback callback);
+  };
+};
