+EchothinkDeviceClearEnrollmentFunction::
+    EchothinkDeviceClearEnrollmentFunction() = default;
+
+EchothinkDeviceClearEnrollmentFunction::
+    ~EchothinkDeviceClearEnrollmentFunction() = default;
+
+ExtensionFunction::ResponseAction
+EchothinkDeviceClearEnrollmentFunction::Run() {
+  if (!IsAuthorizedCaller(this)) {
+    return RespondNow(Error(kUnauthorizedExtensionError));
+  }
+
+  std::optional<BridgeContext> context = GetBridgeContext(this);
+  if (!context) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kMissingDevice)));
+  }
+#if !BUILDFLAG(IS_WIN)
+  return RespondNow(WithArguments(
+      BridgeErrorResult(DeviceBridgeError::kUnsupportedPlatform)));
+#else
+  if (!echothink::device_identity::ResetLocalEnrollmentState(
+          context->local_state, context->profile->GetPrefs(),
+          context->user_data_dir)) {
+    return RespondNow(
+        WithArguments(BridgeErrorResult(DeviceBridgeError::kReset)));
+  }
+
+  base::Value::Dict result = BuildStatusResult(*context);
+  result.Set("reset", true);
+  return RespondNow(WithArguments(std::move(result)));
+#endif
+}
