 }
 
+DeviceBridgeError SignProofPayload(PrefService* local_state,
+                                   const base::FilePath& user_data_dir,
+                                   std::string_view payload,
+                                   ProofSignature* signature) {
+#if !BUILDFLAG(IS_WIN)
+  return DeviceBridgeError::kUnsupportedPlatform;
+#else
+  if (!signature || !local_state || user_data_dir.empty()) {
+    return DeviceBridgeError::kMissingDevice;
+  }
+
+  const base::FilePath key_path =
+      GetProtectedKeyFilePathForUserDataDir(user_data_dir);
+  if (!base::PathExists(key_path)) {
+    return DeviceBridgeError::kMissingDevice;
+  }
+
+  std::optional<crypto::keypair::PrivateKey> private_key =
+      ReadProtectedKeyEnvelope(key_path);
+  if (!private_key) {
+    return DeviceBridgeError::kLockedKey;
+  }
+
+  std::optional<PublicKeyMetadata> metadata =
+      BuildPublicKeyMetadata(*private_key);
+  if (!metadata) {
+    return DeviceBridgeError::kLockedKey;
+  }
+
+  const std::vector<uint8_t> payload_bytes(payload.begin(), payload.end());
+  std::vector<uint8_t> signed_payload = crypto::sign::Sign(
+      crypto::sign::ECDSA_SHA256, *private_key,
+      base::span<const uint8_t>(payload_bytes.data(), payload_bytes.size()));
+  if (signed_payload.empty()) {
+    return DeviceBridgeError::kLockedKey;
+  }
+
+  signature->key_id = metadata->key_id;
+  signature->key_algorithm = kDeviceKeyAlgorithm;
+  signature->signature_base64url = BytesToBase64Url(
+      BytesAsStringView(signed_payload.data(), signed_payload.size()));
+  return DeviceBridgeError::kNone;
+#endif
+}
