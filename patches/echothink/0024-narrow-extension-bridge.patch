+#include "chrome/browser/extensions/api/echothink_device/echothink_device_api.h"
+
+#include <optional>
+#include <string>
+#include <string_view>
+
+#include "base/files/file_path.h"
+#include "base/path_service.h"
+#include "base/values.h"
+#include "build/build_config.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/echothink/device_identity/device_identity_service.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/chrome_paths.h"
+#include "components/prefs/pref_service.h"
+#include "extensions/common/extension.h"
+
+namespace extensions {
+namespace {
+
+constexpr char kBundledWorkspaceExtensionId[] =
+    "lokdibgfmiemhdoogailbfpdggndpolk";
+constexpr char kUnauthorizedExtensionError[] = "unauthorized_extension";
+constexpr char kInvalidPayloadError[] = "invalid_payload";
+constexpr size_t kMaxProofPayloadBytes = 16 * 1024;
+
+using echothink::device_identity::DeviceBridgeError;
+
+struct BridgeContext {
+  Profile* profile = nullptr;
+  PrefService* local_state = nullptr;
+  base::FilePath user_data_dir;
+};
+
+bool IsAuthorizedCaller(const ExtensionFunction* function) {
+  const Extension* extension = function->extension();
+  return extension && extension->id() == kBundledWorkspaceExtensionId;
+}
+
+bool IsPlatformSupported() {
+#if BUILDFLAG(IS_WIN)
+  return true;
+#else
+  return false;
+#endif
+}
+
+std::string_view BridgeErrorToString(DeviceBridgeError error) {
+  switch (error) {
+    case DeviceBridgeError::kNone:
+      return "";
+    case DeviceBridgeError::kMissingDevice:
+      return "missing_device";
+    case DeviceBridgeError::kLockedKey:
+      return "locked_key";
+    case DeviceBridgeError::kUnsupportedPlatform:
+      return "unsupported_platform";
+    case DeviceBridgeError::kReset:
+      return "reset";
+  }
+  return "bridge_error";
+}
+
+base::Value::Dict ErrorResult(std::string_view error) {
+  base::Value::Dict result;
+  result.Set("ok", false);
+  result.Set("error", std::string(error));
+  return result;
+}
+
+base::Value::Dict BridgeErrorResult(DeviceBridgeError error) {
+  return ErrorResult(BridgeErrorToString(error));
+}
+
+std::optional<BridgeContext> GetBridgeContext(ExtensionFunction* function) {
+  if (!g_browser_process || !g_browser_process->local_state()) {
+    return std::nullopt;
+  }
+
+  base::FilePath user_data_dir;
+  if (!base::PathService::Get(chrome::DIR_USER_DATA, &user_data_dir) ||
+      user_data_dir.empty()) {
+    return std::nullopt;
+  }
+
+  BridgeContext context;
+  context.profile = Profile::FromBrowserContext(function->browser_context());
+  context.local_state = g_browser_process->local_state();
+  context.user_data_dir = user_data_dir;
+  if (!context.profile || !context.profile->GetPrefs()) {
+    return std::nullopt;
+  }
+  return context;
+}
+
+bool ProfileNeedsReset(PrefService* profile_prefs) {
+  const std::string enrollment_status = profile_prefs->GetString(
+      echothink::device_identity::kProfileEnrollmentStatusPref);
+  return enrollment_status == "reset_required" ||
+         enrollment_status == "revoked";
+}
+
+DeviceBridgeError EnsureEnrollmentMaterial(PrefService* local_state,
+                                           const base::FilePath& user_data_dir) {
+  const echothink::device_identity::EnsureDeviceIdentityResult result =
+      echothink::device_identity::EnsureDeviceIdentity(local_state,
+                                                       user_data_dir);
+  switch (result) {
+    case echothink::device_identity::EnsureDeviceIdentityResult::kReady:
+    case echothink::device_identity::EnsureDeviceIdentityResult::kGenerated:
+      return DeviceBridgeError::kNone;
+    case echothink::device_identity::EnsureDeviceIdentityResult::
+        kUnsupportedPlatform:
+      return DeviceBridgeError::kUnsupportedPlatform;
+    case echothink::device_identity::EnsureDeviceIdentityResult::kStorageError:
+      return DeviceBridgeError::kMissingDevice;
+    case echothink::device_identity::EnsureDeviceIdentityResult::
+        kInvalidProtectedKey:
+      return DeviceBridgeError::kLockedKey;
+  }
+  return DeviceBridgeError::kLockedKey;
+}
+
+base::Value::Dict BuildStatusResult(const BridgeContext& context) {
+  PrefService* local_state = context.local_state;
+  PrefService* profile_prefs = context.profile->GetPrefs();
+
+  base::Value::Dict result;
+  result.Set("ok", true);
+  result.Set("supported", IsPlatformSupported());
+  result.Set("has_protected_key",
+             echothink::device_identity::HasProtectedDeviceKey(
+                 local_state, context.user_data_dir));
+  result.Set("installation_id",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceInstallationIdPref));
+  result.Set("key_id",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceKeyIdPref));
+  result.Set("key_algorithm",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceKeyAlgorithmPref));
+  result.Set("key_storage",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceKeyStoragePref));
+  result.Set("key_created_at",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceKeyCreatedAtPref));
+  result.Set("browser_channel",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceBrowserChannelPref));
+  result.Set("browser_version",
+             local_state->GetString(
+                 echothink::device_identity::kDeviceBrowserVersionPref));
+
+  const base::Value::Dict& public_key_jwk =
+      local_state->GetDict(
+          echothink::device_identity::kDevicePublicKeyJwkPref);
+  if (!public_key_jwk.empty()) {
+    result.Set("public_key_jwk", public_key_jwk.Clone());
+  }
+
+  result.Set("device_id",
+             profile_prefs->GetString(
+                 echothink::device_identity::kProfileDeviceIdPref));
+  result.Set("enrollment_status",
+             profile_prefs->GetString(
+                 echothink::device_identity::kProfileEnrollmentStatusPref));
+  result.Set("enrolled_at",
+             profile_prefs->GetString(
+                 echothink::device_identity::kProfileEnrolledAtPref));
+  result.Set("last_verified_at",
+             profile_prefs->GetString(
+                 echothink::device_identity::kProfileLastVerifiedAtPref));
+  result.Set("revoked_at",
+             profile_prefs->GetString(
+                 echothink::device_identity::kProfileRevokedAtPref));
+  result.Set("enrolled",
+             profile_prefs->GetBoolean(
+                 echothink::device_identity::kDeviceEnrolledPref));
+  result.Set("verified",
+             profile_prefs->GetBoolean(
+                 echothink::device_identity::kDeviceVerifiedPref));
+  result.Set("setup_complete",
+             profile_prefs->GetBoolean(
+                 echothink::device_identity::kSetupCompletePref));
+  result.Set("reset_required", ProfileNeedsReset(profile_prefs));
+  return result;
+}
+
+std::optional<std::string_view> GetPayloadArgument(
+    const base::Value::List& args) {
+  if (args.empty() || !args[0].is_dict()) {
+    return std::nullopt;
+  }
+
+  const std::string* payload = args[0].GetDict().FindString("payload");
+  if (!payload || payload->empty() ||
+      payload->size() > kMaxProofPayloadBytes) {
+    return std::nullopt;
+  }
+  return std::string_view(*payload);
+}
+
+}  // namespace
+
+EchothinkDeviceGetDeviceStatusFunction::
+    EchothinkDeviceGetDeviceStatusFunction() = default;
+
+EchothinkDeviceGetDeviceStatusFunction::
+    ~EchothinkDeviceGetDeviceStatusFunction() = default;
+
+ExtensionFunction::ResponseAction
+EchothinkDeviceGetDeviceStatusFunction::Run() {
+  if (!IsAuthorizedCaller(this)) {
+    return RespondNow(Error(kUnauthorizedExtensionError));
+  }
+
+  std::optional<BridgeContext> context = GetBridgeContext(this);
+  if (!context) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kMissingDevice)));
+  }
+
+  return RespondNow(WithArguments(BuildStatusResult(*context)));
+}
+
+EchothinkDeviceRequestEnrollmentChallengeFunction::
+    EchothinkDeviceRequestEnrollmentChallengeFunction() = default;
+
+EchothinkDeviceRequestEnrollmentChallengeFunction::
+    ~EchothinkDeviceRequestEnrollmentChallengeFunction() = default;
+
+ExtensionFunction::ResponseAction
+EchothinkDeviceRequestEnrollmentChallengeFunction::Run() {
+  if (!IsAuthorizedCaller(this)) {
+    return RespondNow(Error(kUnauthorizedExtensionError));
+  }
+
+  std::optional<BridgeContext> context = GetBridgeContext(this);
+  if (!context) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kMissingDevice)));
+  }
+  if (ProfileNeedsReset(context->profile->GetPrefs())) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kReset)));
+  }
+
+  const DeviceBridgeError ensure_error =
+      EnsureEnrollmentMaterial(context->local_state, context->user_data_dir);
+  if (ensure_error != DeviceBridgeError::kNone) {
+    return RespondNow(WithArguments(BridgeErrorResult(ensure_error)));
+  }
+
+  base::Value::Dict result = BuildStatusResult(*context);
+  result.Set("challenge_type", "local_public_key_registration");
+  result.Set("challenge_version", "echothink-device-enrollment-v1");
+  return RespondNow(WithArguments(std::move(result)));
+}
+
+EchothinkDeviceSignProofPayloadFunction::
+    EchothinkDeviceSignProofPayloadFunction() = default;
+
+EchothinkDeviceSignProofPayloadFunction::
+    ~EchothinkDeviceSignProofPayloadFunction() = default;
+
+ExtensionFunction::ResponseAction
+EchothinkDeviceSignProofPayloadFunction::Run() {
+  if (!IsAuthorizedCaller(this)) {
+    return RespondNow(Error(kUnauthorizedExtensionError));
+  }
+
+  std::optional<std::string_view> payload = GetPayloadArgument(args());
+  if (!payload) {
+    return RespondNow(WithArguments(ErrorResult(kInvalidPayloadError)));
+  }
+
+  std::optional<BridgeContext> context = GetBridgeContext(this);
+  if (!context) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kMissingDevice)));
+  }
+  if (ProfileNeedsReset(context->profile->GetPrefs())) {
+    return RespondNow(WithArguments(
+        BridgeErrorResult(DeviceBridgeError::kReset)));
+  }
+
+  echothink::device_identity::ProofSignature signature;
+  const DeviceBridgeError sign_error =
+      echothink::device_identity::SignProofPayload(
+          context->local_state, context->user_data_dir, *payload, &signature);
+  if (sign_error != DeviceBridgeError::kNone) {
+    return RespondNow(WithArguments(BridgeErrorResult(sign_error)));
+  }
+
+  base::Value::Dict result;
+  result.Set("ok", true);
+  result.Set("key_id", signature.key_id);
+  result.Set("key_algorithm", signature.key_algorithm);
+  result.Set("signature", signature.signature_base64url);
+  result.Set("signature_encoding", "base64url_der_ecdsa_sha256");
+  return RespondNow(WithArguments(std::move(result)));
+}
