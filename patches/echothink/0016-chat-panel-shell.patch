+      if (text) {
+        receivedText = true;
+        appendToMessage(messageBody, text);
+      }
+    }
+  }
+
+  const finalText = extractStreamText(buffer);
+  if (finalText && finalText !== STREAM_DONE) {
+    receivedText = true;
+    appendToMessage(messageBody, finalText);
+  }
+
+  if (!receivedText) {
+    messageBody.textContent = "No response content.";
+  }
