+    await renderStreamingChatResponse(response, messageBody);
+    return;
+  }
+
+  if (contentType.includes("text/plain")) {
+    await renderRawStreamingChatResponse(response, messageBody);
+    return;
+  }
+
+  await renderBufferedChatResponse(response, messageBody);
+}
