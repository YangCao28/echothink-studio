# Echothink-Patch: 0003-new-tab-and-first-run
# Title: Add local Echothink New Tab fallback / first-run page
# Area: new-tab, first-run
# Depends-On: echothink/0002-default-policies-and-preferences.patch (the normal-profile New Tab route to https://app.echothink.ai/newtab is seeded there via the inherited custom-ntp hook; this patch adds the local fallback that route degrades to when the workspace is unauthenticated or unavailable)
# Inherited-Depends-On: extra/ungoogled-chromium/first-run-page.patch (this patch reuses that patch's local-WebUI URLDataSource pattern and adds Echothink entries adjacent to the lines it introduces in chrome_browser_main.cc, chrome_web_ui_configs.cc, and webui_url_constants.cc, so it must apply after it)
# Browser-Layer-Reason: The fallback/first-run landing page must render before any Echothink service is reachable (offline, signed-out, or pre-enrollment). It therefore has to be a local browser-shell WebUI compiled into the binary; a backend service cannot serve the page that exists precisely for when the backend is unreachable. The page carries only static navigation links to login, device enrollment, diagnostics, update, and support/download, so it contains no business logic or protected data.
# Preferred-Surface-Checked: existing-hook (reuses the inherited local-WebUI URLDataSource pattern from first-run-page.patch and the inherited New Tab route hook from 0002; no new native subsystem is introduced)
# Security-Critical-Areas: none (read-only static local page; no script, no network calls, no access to history/downloads/cookies/passwords/TLS/sandbox/renderer internals)
# Native-Files-Touched: chrome/browser/ui/webui/echothink_first_run.h (new), chrome/browser/ui/webui/chrome_web_ui_configs.cc, chrome/common/webui_url_constants.cc, chrome/browser/chrome_browser_main.cc
# Rebase-Risk: medium (depends on the inherited first-run-page.patch having already added the ungoogled-first-run WebUI registration and host, and on the inherited first-run AddFirstRunTabs block)
# Validation: Apply inherited patches, then echothink/0001..0002, then this patch with `patch -p1` against pinned Chromium 148.0.7778.178; build and confirm: (1) a normal-profile New Tab still resolves to https://app.echothink.ai/newtab (seeded by 0002); (2) chrome://echothink-first-run renders the local fallback page fully offline with only the login, device-enrollment, diagnostics, update, and support/download links; (3) first launch opens chrome://echothink-first-run; (4) the page contains no workspace/business data. Incognito New Tab behavior, native bookmark/history/download/password/cookie/DevTools behavior must remain inherited.
#
# Notes:
# - The authenticated New Tab route (https://app.echothink.ai/newtab) is owned by
#   0002 via the inherited HandleNewTabPageLocationOverride() hook and is NOT
#   re-edited here, so the two patches never touch the same lines. This patch only
#   adds the local fallback surface that route degrades to when the workspace is
#   unreachable or the user is not signed in / not enrolled.
# - The fallback page is a static local WebUI served by an in-memory
#   URLDataSource (the same pattern the inherited first-run-page.patch uses for
#   chrome://ungoogled-first-run). It requires no network access and renders
#   fully offline. It needs no JavaScript, so the WebUI default CSP is left in
#   place (no script-src override).
# - The page links ONLY to the allowed unauthenticated destinations from the
#   change plan section 5.4 / 5.8: login, device enrollment, diagnostics, update,
#   and support/download. It embeds no workspace content, no user data, and no
#   protected business data.
# - First-run behavior is additive: chrome://echothink-first-run is added as the
#   first first-run tab BEFORE the inherited chrome://ungoogled-first-run tab, so
#   the inherited Ungoogled first-run how-to page is preserved while the Echothink
#   login-gate landing page opens in the foreground on first launch.
# - chrome://echothink-diagnostics is referenced as the diagnostics link target
#   per the change plan's allowed-destination list; the diagnostics WebUI itself
#   is owned by a later task (change plan section 5.8). Until that lands, the
#   diagnostics link is a known dead chrome:// link, documented in the task note.

--- a/chrome/browser/ui/webui/echothink_first_run.h
+++ b/chrome/browser/ui/webui/echothink_first_run.h
@@ -0,0 +1,121 @@
+#ifndef CHROME_BROWSER_UI_WEBUI_ECHOTHINK_FIRST_RUN_H_
+#define CHROME_BROWSER_UI_WEBUI_ECHOTHINK_FIRST_RUN_H_
+
+#include "base/memory/ref_counted_memory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/url_data_source.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
