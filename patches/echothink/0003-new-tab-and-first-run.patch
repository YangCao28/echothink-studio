+// Echothink Browser: local fallback / first-run landing page.
+//
+// This page exists for the states in which the remote Echothink workspace
+// (https://app.echothink.ai/newtab, seeded as the New Tab route in
+// echothink/0002) is not usable: offline, signed-out, or pre-enrollment. It is
+// a static, script-free local WebUI so it renders without any backend service.
+// It links only to the allowed unauthenticated destinations and embeds no
+// workspace or business data.
+class EFRDataSource : public content::URLDataSource {
+ public:
+  EFRDataSource() {}
+  EFRDataSource(const EFRDataSource&) = delete;
+  EFRDataSource& operator=(const EFRDataSource&) = delete;
+  std::string GetSource() { return "echothink-first-run"; }
+  std::string GetMimeType(const GURL& url) { return "text/html"; }
+  void StartDataRequest(const GURL& url,
+                        const content::WebContents::Getter& wc_getter,
+                        GotDataCallback callback) {
+    std::string source = R"(
+<!doctype html>
+<title>Echothink Browser</title>
+<meta charset="utf-8">
+<meta name="color-scheme" content="light dark">
+<style>
+ @import url(chrome://resources/css/text_defaults_md.css);
+ html{color:#202124; background:#f5f6f7; line-height:1.4}
+ body{margin:0}
+ a{color:#1967d2; text-decoration:none}
+ a:hover{text-decoration:underline}
+ main{max-width:42em; margin:5em auto; padding:0 1.5em}
+ section{background:white; border-radius:.75em; padding:2em 2.25em; margin-bottom:1.5em;
+         box-shadow:0 .063em .125em 0 #c4c5c6, 0 .125em .375em .125em #e2e3e3}
+ h1{font-size:1.5em; margin:0 0 .25em}
+ h2{font-size:1.05em; margin:0 0 .75em}
+ p{margin:.5em 0; color:#3c4043}
+ ul{list-style:none; padding:0; margin:.5em 0}
+ li{padding:.4em 0; border-top:.063em solid #f0f0f0}
+ li:first-child{border-top:none}
+ .desc{color:#5f6368; font-size:.9em}
+ footer{text-align:center; color:#5f6368; font-size:.85em; margin-top:2em}
+ @media(prefers-color-scheme:dark){
+  html{color:#e8eaed; background:#202124}
+  a{color:#8ab4f8}
+  section{background:#292a2d; box-shadow:0 .063em .125em 0 #161719, 0 .125em .375em .125em #1b1c1f}
+  p{color:#bdc1c6}
+  li{border-top:.063em solid #3f4042}
+  .desc{color:#9aa0a6}
+ }
+</style>
+<main>
+ <section>
+  <h1>Echothink Browser</h1>
+  <p>Your Echothink workspace is not available right now. This can happen when
+   you are offline, not signed in, or your device is not yet enrolled.</p>
+  <p>This is a local page built into the browser. It works without a network
+   connection and does not contain any workspace data. Use the links below to
+   get back into your workspace.</p>
+ </section>
+ <section>
+  <h2>Get back in</h2>
+  <ul>
+   <li><a href="https://auth.echothink.ai/login">Sign in</a>
+    <div class="desc">Sign in to your Echothink account.</div></li>
+   <li><a href="https://auth.echothink.ai/device/enroll">Enroll this device</a>
+    <div class="desc">Register this browser installation with your organization.</div></li>
+  </ul>
+ </section>
+ <section>
+  <h2>Troubleshoot</h2>
+  <ul>
+   <li><a href="chrome://echothink-diagnostics">Diagnostics</a>
+    <div class="desc">Check local browser and connectivity status.</div></li>
+   <li><a href="https://updates.echothink.ai/">Check for updates</a>
+    <div class="desc">Make sure Echothink Browser is up to date.</div></li>
+  </ul>
+ </section>
+ <section>
+  <h2>Help</h2>
+  <ul>
+   <li><a href="https://app.echothink.ai/support">Support</a>
+    <div class="desc">Get help with Echothink Browser.</div></li>
+   <li><a href="https://app.echothink.ai/download-browser">Download Echothink Browser</a>
+    <div class="desc">Reinstall or get Echothink Browser for another device.</div></li>
+  </ul>
+ </section>
+ <footer>
+  This page can always be reached at chrome://echothink-first-run
+ </footer>
+</main>
+)";
+    std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(std::move(source)));
+  }
+};
+
+class EchothinkFirstRun;
+class EchothinkFirstRunUIConfig : public content::DefaultWebUIConfig<EchothinkFirstRun> {
+ public:
+  EchothinkFirstRunUIConfig() : DefaultWebUIConfig("chrome", "echothink-first-run") {}
+};
+
+class EchothinkFirstRun : public content::WebUIController {
+ public:
+  EchothinkFirstRun(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+    content::URLDataSource::Add(Profile::FromWebUI(web_ui), std::make_unique<EFRDataSource>());
+  }
+  EchothinkFirstRun(const EchothinkFirstRun&) = delete;
+  EchothinkFirstRun& operator=(const EchothinkFirstRun&) = delete;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_ECHOTHINK_FIRST_RUN_H_
