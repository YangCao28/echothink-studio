{
  "manifest_version": 3,
  "name": "Echothink Workspace",
  "short_name": "Workspace",
  "description": "Bundled Echothink Browser workspace side panel shell.",
  "version": "0.1.0",
  "minimum_chrome_version": "148",
  "key": "MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQCthl3qbne1pqv+1vpBMhGRJEFbPhKRfpXNm9jTwgx0AirM3qyIfLO0QSQQwxFchJx2Y8tk1IdvgI5DbLrgV+PLRU1Ip9EwbiwDPtTUMuRwZkyWgWFcYrLq/Gf7hTzIaL0OwKKyBNxItaK7g+CFFFWcWZ/DPAvQLebl5+mvV6qU1QIDAQAB",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://app.echothink.ai/*",
    "https://auth.echothink.ai/*",
    "https://api.echothink.ai/*",
    "https://search.echothink.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Echothink Workspace"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.echothink.ai/*",
        "https://auth.echothink.ai/*"
      ],
      "js": [
        "content_bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
